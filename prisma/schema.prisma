// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         String       @default("USER") // USER, ADMIN
  xp           Int          @default(0)
  level        Int          @default(1)
  streak       Int          @default(0)
  lastActive   DateTime     @default(now())
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  emailVerified          DateTime?
  isPremium              Boolean      @default(false)
  razorpayCustomerId     String?
  razorpaySubscriptionId String?
  submissions            Submission[]
  discussions            Discussion[]
  notes                  Note[]
  
  // Quiz Arena Relations
  quizAttempts           QuizAttempt[]
  quizSessions           QuizSession[]
  quizStats              UserQuizStat?
  badges                 UserBadge[]
  friendships            Friendship[]  @relation("UserFriendships")
  friendOf               Friendship[]  @relation("FriendOfUser")
}

model Problem {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  difficulty      String       // EASY, MEDIUM, HARD
  category        String       @default("DSA") // DSA, SQL, etc.
  statement       String       // Markdown
  constraints     String       // Markdown
  examplesJson    String       // JSON string of arrays of input/output
  hintsJson       String       // JSON string of string arrays
  editorial       String       // Markdown
  timeComplexity  String
  spaceComplexity String
  companiesJson   String       // JSON string of string arrays
  tagsJson        String       // JSON string of string arrays
  acceptanceRate  Float        @default(0.0)
  premium         Boolean      @default(false)
  orderIndex      Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  testCases       TestCase[]
  submissions     Submission[]
  discussions     Discussion[]
  notes           Note[]
}

model TestCase {
  id             String   @id @default(cuid())
  problemId      String
  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input          String
  expectedOutput String
  isSample       Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model Submission {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId     String
  problem       Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  code          String
  language      String
  status        String   // PENDING, ACCEPTED, WRONG_ANSWER, TIME_LIMIT_EXCEEDED, RUNTIME_ERROR, COMPILE_ERROR
  executionTime Int      // in ms
  memoryUsage   Int      // in KB
  error         String?
  createdAt     DateTime @default(now())
}

model Contest {
  id            String   @id @default(cuid())
  title         String
  description   String
  startTime     DateTime
  endTime       DateTime
  problemsJson  String   // JSON array of problem IDs
  standingsJson String   @default("[]") // JSON string of standings
  createdAt     DateTime @default(now())
}

model Badge {
  id             String   @id @default(cuid())
  name           String
  description    String
  icon           String   // Lucide icon key name
  conditionType  String   // XP, PROBLEMS_SOLVED, STREAK, CONTEST_RATING
  conditionValue Int
  createdAt      DateTime @default(now())
}

model Discussion {
  id        String       @id @default(cuid())
  problemId String
  problem   Problem      @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?      // Nullable for replies
  content   String
  createdAt DateTime     @default(now())
  parentId  String?
  parent    Discussion?  @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Discussion[] @relation("Replies")
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, problemId])
}

// -----------------------------------------
// Quiz Arena Models
// -----------------------------------------

model QuizQuestion {
  id            String        @id @default(cuid())
  language      String
  category      String
  difficulty    String
  question      String
  optionsJson   String        // JSON array of strings
  correctAnswer Int           // Index of the correct option
  explanation   String?
  xpReward      Int           @default(10)
  createdAt     DateTime      @default(now())
  attempts      QuizAttempt[]
}

model QuizAttempt {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId     String
  question       QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  sessionId      String?
  session        QuizSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  selectedAnswer Int
  isCorrect      Boolean
  timeTaken      Int          // in milliseconds
  createdAt      DateTime     @default(now())
}

model QuizSession {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode       String        // Quick, Topic, Survival, SpeedRun, Daily, 1v1
  score      Int           @default(0)
  accuracy   Float         @default(0.0)
  xpEarned   Int           @default(0)
  completedAt DateTime?
  createdAt  DateTime      @default(now())
  attempts   QuizAttempt[]
}

model UserQuizStat {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalPlayed   Int      @default(0)
  totalCorrect  Int      @default(0)
  totalWrong    Int      @default(0)
  accuracy      Float    @default(0.0)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  totalXP       Int      @default(0)
  level         Int      @default(1)
  rank          String   @default("Rookie")
  updatedAt     DateTime @updatedAt
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId    String   // Can point to existing Badge model or be string key
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model DailyChallenge {
  id            String   @id @default(cuid())
  date          DateTime @unique
  challengeJson String   // JSON of daily questions
  rewardsJson   String   // JSON of XP/coins
  createdAt     DateTime @default(now())
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friendId  String
  friend    User     @relation("FriendOfUser", fields: [friendId], references: [id], onDelete: Cascade)
  status    String   @default("ACCEPTED") // PENDING, ACCEPTED
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
}

// -----------------------------------------
// Authentication & Security Models
// -----------------------------------------

model EmailOTP {
  id        String   @id @default(cuid())
  email     String
  otpHash   String
  purpose   String   // signup, forgot_password
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
}

model RateLimit {
  id        String   @id @default(cuid())
  ip        String
  action    String   // signup_otp, forgot_password_otp, login
  count     Int      @default(1)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ip, action])
  @@index([expiresAt])
}
